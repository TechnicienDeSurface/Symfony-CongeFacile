{% extends 'base.html.twig' %}

{% block body %}
<div class="container mx-auto mt-10">
    <div class="bg-white p-6 rounded-lg shadow-lg">
        <h2 class="text-2xl font-bold text-gray-800 mb-4"></h2>

        {{ form_start(form) }}
            <div class="mb-4">
                {{ form_label(form.name, 'Nom du service', {'class': 'block font-medium text-gray-700'}) }}
                {{ form_widget(form.name) }}
            </div>
            
            <div class="flex space-x-2">
                {{ form_widget(form.delete, {'attr': {'class': 'bg-red-500 hover:bg-red-700 text-white font-bold py-2 px-4 rounded'}}) }}
                {{ form_widget(form.save, {'attr': {'class': 'bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded'}}) }}
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
